PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.example.mongodb.net/mediflow?retryWrites=true&w=majority

# REQUIRED — must be at least 32 characters. Server refuses to start without it.
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_this_with_a_64_char_random_hex_string

# Production only — restrict CORS to your deployed frontend URL.
# Leave empty in development (defaults to allowing all origins).
CLIENT_ORIGIN=https://your-frontend-domain.com

# Used only by scripts/createAdmin.js to seed the first admin account.
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@mediflow.com
ADMIN_PASSWORD=replace_this_with_a_strong_password
ADMIN_PHONE=9999999999
